@article{schutzSimLODSimultaneousLOD2024,
  title = {{{SimLOD}}: {{Simultaneous LOD Generation}} and {{Rendering}} for {{Point Clouds}}},
  shorttitle = {{{SimLOD}}},
  author = {Schütz, Markus and Herzberger, Lukas and Wimmer, Michael},
  date = {2024-05-11},
  journaltitle = {Proceedings of the ACM on Computer Graphics and Interactive Techniques},
